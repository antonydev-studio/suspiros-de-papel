## Section Template

```tsx
import { Container } from "@/components/ui/Container"
import { useScrollReveal } from "@/hooks/useScrollReveal"

export function MySection() {
  const ref = useScrollReveal<HTMLElement>()
  return (
    <section ref={ref} className="section-padding scroll-reveal">
      <Container>
        {/* content */}
      </Container>
    </section>
  )
}
```

## Responsive Patterns

Mobile-first always. Use Tailwind breakpoints: `sm:` `md:` `lg:` `xl:`.

```tsx
// Grid: stack on mobile, columns on desktop
<div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

// Typography: fluid with clamp via Tailwind
<h2 className="text-2xl md:text-3xl lg:text-4xl font-headline">

// Spacing: generous and consistent
<section className="section-padding">  {/* uses CSS custom property */}
```

Touch targets: minimum 44Ă—44px for interactive elements.

