# .env.example — Suspiros de Papel
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.

# ── Phase 1: No secrets required ──────────────────────────────────────────────
# WhatsApp number and brand data live in src/constants/site.ts (not secrets).
# No environment variables are needed to run Phase 1.

# ── Phase 2: Supabase ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only, never expose

# ── Phase 2: Admin auth ───────────────────────────────────────────────────────
# Handled by Supabase Auth — no extra env vars required beyond the above.
